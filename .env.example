DOCINTEL_ENVIRONMENT=development
DOCINTEL_DATA_DIR=.data
DOCINTEL_API_HOST=127.0.0.1
DOCINTEL_API_PORT=8014
DOCINTEL_UI_PORT=8514
DOCINTEL_PROVIDER_MODE=deterministic
DOCINTEL_EMBEDDING_PROVIDER=deterministic
DOCINTEL_OPENAI_CHAT_MODEL=gpt-4o-mini
DOCINTEL_OPENAI_VISION_MODEL=gpt-4o-mini
DOCINTEL_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DOCINTEL_ENABLE_OCR=true
DOCINTEL_DEMO_MODE=true

# Optional server-side values. Never commit real values.
# DOCINTEL_OPENAI_API_KEY=
# DOCINTEL_API_TOKEN=

